#define DEVICE_NAME "laser-26-039"
#define DEVICE_SECRET "529cb63d9044999ebfc38abcf5545beb"

const char* MAC_STR = "02:1A:C3:7F:4B:27";
byte mac[6];

// --- STATIC NETWORK (instead of DHCP) ---
IPAddress localIp(10, 0, 196, 148);       // <-- укажи нужный IP
IPAddress dnsIp(8, 8, 8, 8);              // <-- укажи ваш DNS (лучше роутер)
IPAddress gatewayIp(10, 0, 196, 129);     // <-- укажи ваш шлюз
IPAddress subnetMask(255, 255, 255, 224); // <-- укажи вашу маску

const char* serverHost = "nb26.avssr.kz"; // <-- укажи домен сервера
#define SERVER_PORT 3000

#define W5500_CS 10
#define W5500_RST 9

#define DMX_PIN 3
#define RS485_DIR 2

#define LASER_BASE_CHANNEL 10
#define LASER_STEP 10
#define MAX_LASERS 10

EthernetClient client;
RTC_DS3231 rtc;

// ================= STATE =================
bool useOfflineMode = false;
bool offlineNightActive = false;

// ================= SCENE =================
bool sceneActive = false;
int sceneType = 0;
int sceneCount = 0;
int sceneDelay = 0;

unsigned long lastStepTime = 0;
bool toggleState = false;

// ================= NETWORK =================
enum NetState {
  NET_IDLE,
  NET_CONNECT,
  NET_SEND,
  NET_READ
};

NetState netState = NET_IDLE;

unsigned long lastPoll = 0;
unsigned long netTimer = 0;
String responseBuffer = "";

// Проверка линка раз в 10 секунд
unsigned long lastLinkCheck = 0;
const unsigned long linkCheckInterval = 10000;
bool lastLinkUp = true;

// ================= MAC =================
void parseMAC(const char* str, byte* outMac) {
  int v[6];
  sscanf(str, "%x:%x:%x:%x:%x:%x", &v[0], &v[1], &v[2], &v[3], &v[4], &v[5]);
  for (byte i = 0; i < 6; i++) outMac[i] = (byte)v[i];
}

// ================= RESET =================
void resetW5500() {
  pinMode(W5500_RST, OUTPUT);
  digitalWrite(W5500_RST, LOW);
  delay(200);
  digitalWrite(W5500_RST, HIGH);
  delay(800);
}

// FIX: статическая конфигурация через begin(mac, ip, dns, gateway, subnet)
bool applyStaticIP() {
  Ethernet.begin(mac, localIp, dnsIp, gatewayIp, subnetMask);
  delay(300);

  return (Ethernet.localIP() == localIp &&
          Ethernet.subnetMask() == subnetMask &&
          Ethernet.gatewayIP() == gatewayIp);
}

// ================= DIAG =================
void printNetDiag(const __FlashStringHelper* tag) {
  Serial.println();
  Serial.print(F("[NET] === "));
  Serial.print(tag);
  Serial.println(F(" ==="));

  EthernetHardwareStatus hw = Ethernet.hardwareStatus();
  Serial.print(F("[NET] HW: "));
  if (hw == EthernetNoHardware) Serial.println(F("NoHardware"));
  else if (hw == EthernetW5100) Serial.println(F("W5100"));
  else if (hw == EthernetW5200) Serial.println(F("W5200"));
  else if (hw == EthernetW5500) Serial.println(F("W5500"));
  else Serial.println(F("Unknown"));

  EthernetLinkStatus ls = Ethernet.linkStatus();
  Serial.print(F("[NET] LINK: "));
  if (ls == Unknown) Serial.println(F("Unknown"));
  else if (ls == LinkON) Serial.println(F("ON"));
  else if (ls == LinkOFF) Serial.println(F("OFF"));

  Serial.print(F("[NET] MAC: "));
  for (byte i = 0; i < 6; i++) {
    if (mac[i] < 16) Serial.print('0');
    Serial.print(mac[i], HEX);
    if (i < 5) Serial.print(':');
  }
  Serial.println();

  Serial.print(F("[NET] IP : "));
  Serial.println(Ethernet.localIP());
  Serial.print(F("[NET] SN : "));
  Serial.println(Ethernet.subnetMask());
  Serial.print(F("[NET] GW : "));
  Serial.println(Ethernet.gatewayIP());
  Serial.print(F("[NET] DNS: "));
  Serial.println(Ethernet.dnsServerIP());

  Serial.println(F("[NET] ====================="));
}

void syncRTCFromSerial() {
  if (!Serial.available()) return;

  String s = Serial.readStringUntil('\n');
  s.trim();

  int year  = s.substring(0, 4).toInt();
  int month = s.substring(5, 7).toInt();
  int day   = s.substring(8, 10).toInt();
  int hour  = s.substring(11, 13).toInt();
  int min   = s.substring(14, 16).toInt();
  int sec   = s.substring(17, 19).toInt();

  rtc.adjust(DateTime(year, month, day, hour, min, sec));
  Serial.println(F("[RTC] SYNC OK"));
}

// ================= TIME =================
int getHour() {
  DateTime now = rtc.now();
  if (now.year() < 2023) {
    Serial.println(F("[RTC] INVALID → fallback night"));
    return 9;
  }
  return now.hour();
}

// ================= DMX =================
void allOff() {
  sceneActive = false;
  for (int i = 1; i <= 128; i++) DmxSimple.write(i, 0);
}

// ================= COMMAND =================
void parseCommand(String line) {
  line.trim();

  Serial.print(F("[CMD] "));
  Serial.println(line);

  if (line == "O" || line == "0") {
    allOff();
    return;
  }

  int p1 = line.indexOf('|');
  if (p1 == -1) return;

  if (line.substring(0, p1) == "S") {
    allOff();

    int p2 = line.indexOf('|', p1 + 1);
    int p3 = line.indexOf('|', p2 + 1);

    sceneType  = line.substring(p1 + 1, p2).toInt();
    sceneCount = line.substring(p2 + 1, p3).toInt();
    sceneDelay = line.substring(p3 + 1).toInt();

    sceneActive = true;
    lastStepTime = millis() - sceneDelay;
    toggleState = true;

    Serial.println(F("[CMD] SCENE APPLIED"));
  }
}

// ================= OFFLINE =================
void startOfflineScene() {
  Serial.println(F("[OFFLINE] START SCENE 2"));
  parseCommand("S|2|10|1500");
  offlineNightActive = true;
}

// ================= SCENE =================
void updateScene() {
  if (!sceneActive) return;

  int count = (sceneCount > MAX_LASERS) ? MAX_LASERS : sceneCount;

  if (sceneType == 1 || sceneType == 99) {
    byte val = (sceneType == 1) ? 255 : 0;
    for (int i = 0; i < count; i++) {
      int ch = LASER_BASE_CHANNEL + (i * LASER_STEP);
      DmxSimple.write(ch, val);
    }
    return;
  }

  if (sceneType == 2) {
    if (millis() - lastStepTime < (unsigned long)sceneDelay) return;

    lastStepTime = millis();
    toggleState = !toggleState;

    for (int i = 0; i < count; i++) {
      int ch = LASER_BASE_CHANNEL + (i * LASER_STEP);
      bool isEven = !(i & 1);
      int val = toggleState ? (isEven ? 255 : 0) : (isEven ? 0 : 255);
      DmxSimple.write(ch, val);
    }
  }
}

// ================= NETWORK =================
void processNetwork() {
  switch (netState) {
    case NET_IDLE:
      if (millis() - lastPoll > 5000) {
        lastPoll = millis();
        netState = NET_CONNECT;
      }
      break;

    case NET_CONNECT:
      client.stop();
      if (client.connect(serverHost, SERVER_PORT)) { // по домену
        netState = NET_SEND;
      } else {
        useOfflineMode = true;
        netState = NET_IDLE;

        int hour = getHour();
        bool isNight = (hour >= 21 || hour < 5);
        if (isNight && !offlineNightActive) startOfflineScene();
      }
      break;

    case NET_SEND:
      client.println(F("GET /device-agent/commands/pending HTTP/1.1"));
      client.print(F("Host: "));
      client.println(serverHost);
      client.print(F("x-device-unique-name: "));
      client.println(F(DEVICE_NAME));
      client.print(F("x-device-secret-key: "));
      client.println(F(DEVICE_SECRET));
      client.println(F("Connection: close"));
      client.println();

      responseBuffer = "";
      netTimer = millis();
      netState = NET_READ;
      break;

    case NET_READ:
      while (client.available()) responseBuffer += (char)client.read();

      if (!client.connected()) {
        client.stop();
        int bodyStart = responseBuffer.indexOf("\r\n\r\n");
        if (bodyStart != -1) {
          String body = responseBuffer.substring(bodyStart + 4);
          if (body.length() > 0) {
            parseCommand(body);
            useOfflineMode = false;
          } else {
            useOfflineMode = true;
          }
        } else {
          useOfflineMode = true;
        }

        responseBuffer = "";
        netTimer = 0;
        netState = NET_IDLE;
      }

      if (millis() - netTimer > 15000) {
        client.stop();
        useOfflineMode = true;
        responseBuffer = "";
        netTimer = 0;
        netState = NET_IDLE;
      }
      break;
  }
}

void ensureNetwork() {
  if (millis() - lastLinkCheck < linkCheckInterval) return;
  lastLinkCheck = millis();

  bool linkUp = (Ethernet.linkStatus() != LinkOFF);

  if (!linkUp) {
    client.stop();
    allOff();
    offlineNightActive = false;
    useOfflineMode = true;
    responseBuffer = "";
    netTimer = 0;
    netState = NET_IDLE;
    lastLinkUp = false;
    return;
  }

  if (!lastLinkUp && linkUp) {
    client.stop();
    if (applyStaticIP()) {
      printNetDiag(F("RELINK OK"));
      useOfflineMode = false;
      responseBuffer = "";
      netTimer = 0;
      netState = NET_IDLE;
      lastPoll = 0;
    } else {
      printNetDiag(F("RELINK FAIL"));
      useOfflineMode = true;
      responseBuffer = "";
      netTimer = 0;
      netState = NET_IDLE;
    }
  }

  if (linkUp && useOfflineMode) {
    netState = NET_IDLE;
  }

  lastLinkUp = true;
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  pinMode(RS485_DIR, OUTPUT);
  digitalWrite(RS485_DIR, HIGH);

  DmxSimple.usePin(DMX_PIN);
  DmxSimple.maxChannel(128);

  Wire.begin();
  Wire.setClock(100000);

  rtc.begin();
  //rtc.adjust(DateTime(2026, 3, 28, 12, 43, 0));
  Serial.println(rtc.now().timestamp());
  Serial.println(F(DEVICE_NAME));
  parseMAC(MAC_STR, mac);

  Ethernet.init(W5500_CS);
  resetW5500();

  printNetDiag(F("BEFORE APPLY"));

  bool ok = false;
  for (byte i = 0; i < 3; i++) {
    if (applyStaticIP()) {
      ok = true;
      break;
    }
    delay(200);
  }

  printNetDiag(F("AFTER APPLY"));

  if (!ok) {
    Serial.println(F("[NET] STATIC CONFIG FAIL"));
    Serial.print(F("[NET] GOT IP: "));
    Serial.println(Ethernet.localIP());
    useOfflineMode = true;
  } else {
    Serial.print(F("[NET] IP: "));
    Serial.println(Ethernet.localIP());
  }

  lastLinkUp = (Ethernet.linkStatus() != LinkOFF);
}

// ================= LOOP =================
void loop() {
  //syncRTCFromSerial();
  ensureNetwork();
  updateScene();
  processNetwork();

  if (useOfflineMode) {
    int hour = getHour();
    bool isNight = (hour >= 21 || hour < 5);

    if (isNight && !offlineNightActive) startOfflineScene();

    if (!isNight && offlineNightActive) {
      allOff();
      offlineNightActive = false;
    }
  }
}
