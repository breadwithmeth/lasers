#include <SPI.h>
#include <Ethernet.h>
#include <DmxSimple.h>
#include <Wire.h>
#include <RTClib.h>

// ================= CONFIG =================
#define DEVICE_NAME "laser-26-002"
#define DEVICE_SECRET "1409260cd00dfc4bad0cc5df2f7d0dcf"

const char* MAC_STR = "02:1A:C3:7F:4B:02";
byte mac[6];

IPAddress server(213,148,10,233);
#define SERVER_PORT 3000

#define W5500_CS 10
#define W5500_RST 9

#define DMX_PIN 3
#define RS485_DIR 2

#define LASER_BASE_CHANNEL 10
#define LASER_STEP 10
#define MAX_LASERS 10

EthernetClient client;
RTC_DS3231 rtc;

// ================= STATE =================
bool useOfflineMode = false;
bool offlineNightActive = false;

// ================= SCENE =================
bool sceneActive = false;
int sceneType = 0;
int sceneCount = 0;
int sceneDelay = 0;

unsigned long lastStepTime = 0;
bool toggleState = false;

// ================= NETWORK =================
enum NetState {
  NET_IDLE,
  NET_CONNECT,
  NET_SEND,
  NET_READ
};

NetState netState = NET_IDLE;

unsigned long lastPoll = 0;
unsigned long netTimer = 0;
String responseBuffer = "";

// ================= MAC =================
void parseMAC(const char* str, byte* mac) {
  int v[6];
  sscanf(str, "%x:%x:%x:%x:%x:%x",
    &v[0], &v[1], &v[2], &v[3], &v[4], &v[5]);
  for (int i = 0; i < 6; i++) mac[i] = (byte)v[i];
}

// ================= RESET =================
void resetW5500() {
  pinMode(W5500_RST, OUTPUT);
  digitalWrite(W5500_RST, LOW);
  delay(200);
  digitalWrite(W5500_RST, HIGH);
  delay(800);
}

void syncRTCFromSerial() {
  if (Serial.available()) {
    String s = Serial.readStringUntil('\n');
    s.trim();

    // формат: 2026-03-25 21:45:00
    int year  = s.substring(0,4).toInt();
    int month = s.substring(5,7).toInt();
    int day   = s.substring(8,10).toInt();
    int hour  = s.substring(11,13).toInt();
    int min   = s.substring(14,16).toInt();
    int sec   = s.substring(17,19).toInt();

    rtc.adjust(DateTime(year, month, day, hour, min, sec));

    Serial.println("[RTC] SYNC OK");
  }
}

// ================= TIME =================
int getHour() {
  DateTime now = rtc.now();

  // защита от мусорного времени
  if (now.year() < 2023) {
    Serial.println("[RTC] INVALID → fallback night");
    return 9;
  }

  return now.hour();
}

// ================= DMX =================
void allOff() {
  sceneActive = false;

  for (int i = 1; i <= 128; i++) {
    DmxSimple.write(i, 0);
  }
}

// ================= COMMAND =================
void parseCommand(String line) {

  line.trim();

  Serial.print("[CMD] ");
  Serial.println(line);

  if (line == "O" || line == "0") {
    allOff();
    return;
  }

  int p1 = line.indexOf('|');
  if (p1 == -1) return;

  String type = line.substring(0, p1);

  if (type == "S") {

    allOff();

    int p2 = line.indexOf('|', p1 + 1);
    int p3 = line.indexOf('|', p2 + 1);

    sceneType = line.substring(p1 + 1, p2).toInt();
    sceneCount = line.substring(p2 + 1, p3).toInt();
    sceneDelay = line.substring(p3 + 1).toInt();

    sceneActive = true;

    // 🔥 КЛЮЧЕВОЙ ФИКС
    lastStepTime = millis() - sceneDelay;
    toggleState = true;

    Serial.println("[CMD] SCENE APPLIED");
  }
}

// ================= OFFLINE =================
void startOfflineScene() {
  Serial.println("[OFFLINE] START SCENE 2");
  parseCommand("S|2|10|1500");
  offlineNightActive = true;
}

// ================= SCENE =================
void updateScene() {

  if (!sceneActive) return;

  int count = sceneCount;
  if (count > MAX_LASERS) count = MAX_LASERS;

  // ===== СЦЕНА 1 =====
  if (sceneType == 1) {
    for (int i = 0; i < count; i++) {
      int ch = LASER_BASE_CHANNEL + (i * LASER_STEP);
      DmxSimple.write(ch, 255);
    }
  }

  // ===== СЦЕНА 99 =====
  if (sceneType == 99) {
    for (int i = 0; i < count; i++) {
      int ch = LASER_BASE_CHANNEL + (i * LASER_STEP);
      DmxSimple.write(ch, 0);
    }
  }

  // ===== СЦЕНА 2 (мигание) =====
  if (sceneType == 2) {

    if (millis() - lastStepTime < sceneDelay) return;

    lastStepTime = millis();
    toggleState = !toggleState;

    for (int i = 0; i < count; i++) {

      int ch = LASER_BASE_CHANNEL + (i * LASER_STEP);
      bool isEven = (i % 2 == 0);

      int val = toggleState
        ? (isEven ? 255 : 0)
        : (isEven ? 0 : 255);

      DmxSimple.write(ch, val);
    }
  }
}

// ================= NETWORK =================
void processNetwork() {

  switch (netState) {

    case NET_IDLE:
      if (millis() - lastPoll > 5000) {
        lastPoll = millis();
        netState = NET_CONNECT;
      }
      break;

    case NET_CONNECT:
      client.stop();

      if (client.connect(server, SERVER_PORT)) {
        netState = NET_SEND;
      } else {
        useOfflineMode = true;
        netState = NET_IDLE;
      }
      break;

    case NET_SEND:
      client.println("GET /device-agent/commands/pending HTTP/1.1");
      client.println("Host: 213.148.10.233");

      client.print("x-device-unique-name: ");
      client.println(DEVICE_NAME);

      client.print("x-device-secret-key: ");
      client.println(DEVICE_SECRET);

      client.println("Connection: close");
      client.println();

      responseBuffer = "";
      netTimer = millis();

      netState = NET_READ;
      break;

    case NET_READ:

      while (client.available()) {
        char c = client.read();
        responseBuffer += c;
      }

      if (!client.connected()) {

        client.stop();

        int bodyStart = responseBuffer.indexOf("\r\n\r\n");
        if (bodyStart != -1) {
          String body = responseBuffer.substring(bodyStart + 4);
          parseCommand(body);
        }

        useOfflineMode = false;
        netState = NET_IDLE;
      }

      if (millis() - netTimer > 15000) {
        client.stop();
        useOfflineMode = true;
        netState = NET_IDLE;
      }

      break;
  }
}

unsigned long lastDhcpRetry = 0;

void ensureNetwork() {
  if (Ethernet.linkStatus() == LinkOFF) {
    return;
  }

  if (Ethernet.localIP()[0] == 0) {

    if (millis() - lastDhcpRetry > 15000) {
      lastDhcpRetry = millis();

      Serial.println("[NET] RETRY DHCP");

      if (Ethernet.begin(mac) != 0) {
        Serial.print("[NET] GOT IP: ");
        Serial.println(Ethernet.localIP());

        useOfflineMode = false;
        netState = NET_IDLE;
      }
    }
  }
}

// ================= SETUP =================
void setup() {

  Serial.begin(115200);

  pinMode(RS485_DIR, OUTPUT);
  digitalWrite(RS485_DIR, HIGH);

  DmxSimple.usePin(DMX_PIN);
  DmxSimple.maxChannel(128);

  Wire.begin();
  Wire.setClock(100000); // важно

  rtc.begin();
  //rtc.adjust(DateTime(2026, 3, 26, 00, 10, 0));
  Serial.println(rtc.now().timestamp());
  parseMAC(MAC_STR, mac);

  Ethernet.init(W5500_CS);   // 🔥 ОБЯЗАТЕЛЬНО
  resetW5500();


  if (Ethernet.begin(mac) == 0) {
    Serial.println("[NET] DHCP FAIL");
    useOfflineMode = true;
  } else {
    Serial.print("[NET] IP: ");
    Serial.println(Ethernet.localIP());
  }
}

// ================= LOOP =================
void loop() {
  //syncRTCFromSerial();
  ensureNetwork();
  updateScene();
  processNetwork();

  // ===== OFFLINE =====
  if (useOfflineMode) {

    int hour = getHour();
    bool isNight = (hour >= 21 || hour < 5);

    if (isNight && !offlineNightActive) {
      startOfflineScene();
    }

    if (!isNight && offlineNightActive) {
      allOff();
      offlineNightActive = false;
    }
  }
}
